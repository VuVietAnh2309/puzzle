{% macro main_card(is_player) %}
  <div class="glass-card">
    <div class="title-section">
      <div class="title-main">Quiz<br>Game!</div>
      <div class="title-sub">Chương trình Thi đấu Kiến thức</div>
    </div>
    <div class="form-section">
      {% if is_player %}
        <div class="input-wrapper">
          <input type="text" id="roomCode" class="glass-input" placeholder="Mã phòng" maxlength="10" autocomplete="off" style="text-transform:uppercase;">
        </div>
        <div class="input-wrapper">
          <input type="text" id="playerName" class="glass-input" placeholder="Tên đội" maxlength="30" autocomplete="off">
        </div>
        <button class="btn-action join-btn" onclick="joinGame()">Vào thi</button>
      {% else %}
        <div class="input-wrapper">
          <input type="text" id="adminUser" class="glass-input" placeholder="Tài khoản" required autocomplete="off">
        </div>
        <div class="input-wrapper">
          <input type="password" id="adminPass" class="glass-input" placeholder="Mật khẩu" required autocomplete="off">
          <button type="button" class="eye-toggle" id="eyeIcon" onclick="togglePassword()">
            <svg id="eyeSvg" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
        <button type="button" class="btn-action" onclick="handleAdminLoginDirectly()">Đăng nhập Admin</button>
        <div id="adminLoginError" class="login-err-premium">Sai tài khoản hoặc mật khẩu</div>
      {% endif %}
    </div>
  </div>
{% endmacro %}

{% extends "base.njk" %}

{% block title %}
  {% if is_player %}Thí sinh - Quiz Game{% else %}Quản trị - Quiz Game{% endif %}
{% endblock %}

{% block extra_styles %}
  .logo-item {
    border: 2px solid rgba(0, 191, 255, 0.15); border-radius: 12px; padding: 8px;
    cursor: pointer; transition: all 0.2s; background: rgba(0, 30, 80, 0.3);
    display: flex; align-items: center; justify-content: center; aspect-ratio: 1;
  }
  .logo-item:hover { border-color: rgba(0, 191, 255, 0.4); transform: scale(1.05); }
  .logo-item.selected { border-color: #4dc9f6; box-shadow: 0 0 15px rgba(0, 191, 255, 0.25); background: rgba(0, 100, 200, 0.15); }
  .logo-item img { width: 100%; height: 100%; object-fit: contain; border-radius: 8px; }

  @keyframes slideInDown { from { transform: translate(-50%, -100%); opacity: 0; } to { transform: translate(-50%, 0); opacity: 1; } }
  .p-notification {
    display: none; position: fixed; top: 30px; left: 50%; transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.98); color: #1e293b; padding: 1.5rem 1.8rem;
    border-radius: 20px; box-shadow: 0 15px 45px rgba(0,0,0,0.4); z-index: 10001;
    width: 90%; max-width: 320px; text-align: center; backdrop-filter: blur(15px);
    border: 1px solid rgba(255,255,255,0.4); animation: slideInDown 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .login-err-premium { text-align: center; color: #fb7185; font-size: 0.85rem; font-weight: 700; margin-top: 1rem; display: none; }
{% endblock %}

{% block content %}
  <div id="joinScreen" class="screen-flex active join-screen">
    {{ main_card(is_player=is_player) }}
  </div>

  {% if is_player %}
    <!-- Player Screens (keeping minimal for correct script behavior) -->
    <div id="logoScreen" class="screen"><div class="join-screen"><div class="glass-card"><h2 style="text-align:center;">Chọn logo đội thi</h2><div id="logoGrid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-top:1.5rem;"></div><button id="btnConfirmLogo" class="btn-action" style="margin-top:1.5rem;" onclick="confirmLogo()">Xác nhận</button></div></div></div>
    <div id="waitingScreen" class="screen">
      <div class="waiting-screen">
        <div class="glass-card">
          <div class="waiting-check">✓</div>
          <div class="waiting-name" id="waitingName"></div>
          <div class="waiting-text">Đã vào phòng!</div>
          <div id="testStartContainer" style="display:none;margin-top:1.5rem;">
            <button class="btn-action" onclick="startTestNow()">Bắt đầu thử nghiệm</button>
          </div>
        </div>
      </div>
    </div>
    <div id="questionScreen" class="screen">
      <div class="question-screen-player">
        <div class="question-top-bar">
          <div class="question-counter" id="pQNum">Câu 1 / 20</div>
        </div>
        <div class="question-center">
          <div class="question-timer-big" id="pTimer">15</div>
          <div class="question-text-display" id="pQText"></div>
        </div>
        <div class="answers-grid" id="pAnswersGrid"></div>
        <div class="admin-bottom-bar">
          <div style="height:20px;"></div>
        </div>
      </div>
    </div>
    <div id="answeredScreen" class="screen">
      <div class="answered-screen" style="display:flex;align-items:center;justify-content:center;min-height:100vh;flex-direction:column;text-align:center;padding:2rem;">
        <div style="font-size:3rem;margin-bottom:1rem;">✓</div>
        <h2 style="font-weight:900;margin-bottom:0.5rem;">ĐÃ TRẢ LỜI</h2>
        <p id="answeredSub" style="color:rgba(255,255,255,0.7);font-weight:600;">Đang chờ kết quả...</p>
      </div>
    </div>
    <div id="resultScreen" class="screen">
      <div class="result-player-screen" style="display:flex;align-items:center;justify-content:center;min-height:100vh;flex-direction:column;text-align:center;padding:2rem;">
        <div id="resultIcon" class="result-player-icon"></div>
        <h2 id="resultTitle" class="result-player-title">KẾT QUẢ</h2>
        <div id="resultStreak" style="display:none;margin:0.5rem 0;">
          <span id="resultStreakText" style="color:#fbbf24;font-weight:800;font-size:0.9rem;letter-spacing:2px;"></span>
        </div>
        <div id="resultPointsLabel" style="color:rgba(255,255,255,0.5);font-size:0.8rem;font-weight:700;letter-spacing:3px;margin-top:1rem;">POINTS EARNED</div>
        <div id="resultPointsNum" style="font-size:3rem;font-weight:900;margin:0.5rem 0;">0</div>
        <p id="resultSub" style="color:rgba(255,255,255,0.6);font-weight:600;margin-bottom:1.5rem;"></p>
        <div style="width:100%;max-width:300px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
            <span id="resultRankOld" style="font-weight:800;color:rgba(255,255,255,0.5);">#—</span>
            <span id="resultRankChange" class="result-rank-change" style="font-size:0.8rem;font-weight:800;letter-spacing:1px;">—</span>
            <span id="resultRankNew" style="font-weight:800;color:#4dc9f6;">#—</span>
          </div>
          <div style="background:rgba(255,255,255,0.1);border-radius:8px;height:8px;overflow:hidden;">
            <div id="resultRankBar" style="height:100%;width:0%;background:linear-gradient(90deg,#00bfff,#1e90ff);border-radius:8px;transition:width 0.8s ease;"></div>
          </div>
        </div>
      </div>
    </div>
    <div id="rankingScreen" class="screen">
      <div style="display:flex;align-items:center;justify-content:center;min-height:100vh;flex-direction:column;text-align:center;padding:2rem;">
        <h2 id="pRankTitle" style="font-weight:900;margin-bottom:0.5rem;">BẢNG XẾP HẠNG</h2>
        <p id="pRankSub" style="color:rgba(255,255,255,0.6);font-weight:600;margin-bottom:2rem;"></p>
        <div id="pPodium" class="podium" style="display:flex;align-items:flex-end;justify-content:center;gap:10px;margin-bottom:2rem;width:100%;max-width:400px;"></div>
        <div id="pRankingList" style="width:100%;max-width:400px;flex:1;"></div>
        <div class="admin-bottom-bar" style="width:100%;">
          <div style="height:20px;"></div>
        </div>
      </div>
    </div>
    <div id="puzzleScreen" class="screen puzzle-screen-wrapper">
      <div class="puzzle-screen-inner">
        <div class="question-top-bar">
          <div class="question-counter">XẾP HÌNH</div>
          <div style="display:flex;align-items:center;gap:12px;">
            <div class="puzzle-timer-inline" id="pPuzzleTimer">120</div>
            <span id="pPuzzleMoves" style="font-size:0.85rem;font-weight:700;color:rgba(255,255,255,0.6);letter-spacing:1px;">0 lượt đổi</span>
          </div>
        </div>
        <div class="puzzle-board-wrapper">
          <div id="pPuzzleBoard" class="puzzle-board"></div>
        </div>
      </div>
    </div>
    <div id="puzzleCompleteScreen" class="screen">
      <div style="display:flex;align-items:center;justify-content:center;min-height:100vh;flex-direction:column;text-align:center;padding:2rem;">
        <div style="font-size:4rem;margin-bottom:1rem;animation:bounceIn 0.6s ease;">🎉</div>
        <h2 style="font-weight:900;font-size:2.5rem;margin-bottom:1rem;background:linear-gradient(135deg,#4dc9f6,#00bfff,#1e90ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">HOÀN THÀNH!</h2>
        <div style="background:rgba(0,30,80,0.4);border:1px solid rgba(0,191,255,0.15);border-radius:16px;padding:2rem 3rem;margin-bottom:1rem;">
          <div style="font-size:0.8rem;font-weight:700;color:rgba(255,255,255,0.5);letter-spacing:3px;margin-bottom:0.5rem;">THỜI GIAN</div>
          <div id="puzzleCompleteTime" style="font-size:2.5rem;font-weight:900;color:#4dc9f6;">--:--</div>
          <div style="font-size:0.8rem;font-weight:700;color:rgba(255,255,255,0.5);letter-spacing:3px;margin-top:1rem;margin-bottom:0.5rem;">SỐ LƯỢT ĐỔI</div>
          <div id="puzzleCompleteMoves" style="font-size:2rem;font-weight:900;">0</div>
        </div>
        <p style="color:rgba(255,255,255,0.5);font-weight:600;">Đang chờ kết quả chung...</p>
      </div>
    </div>
    <div id="finalScreen" class="screen">
      <div style="display:flex;align-items:center;justify-content:center;min-height:100vh;flex-direction:column;text-align:center;padding:2rem;">
        <h2 style="font-weight:900;font-size:2rem;margin-bottom:0.5rem;">KẾT QUẢ CHUNG CUỘC</h2>
        <div id="pFinalPodium" class="podium" style="display:flex;align-items:flex-end;justify-content:center;gap:10px;margin:2rem 0;width:100%;max-width:400px;"></div>
        <div id="pFinalList" style="width:100%;max-width:400px;flex:1;"></div>
        <div id="testReplayContainer" style="display:none;margin-top:1.5rem;"></div>
        <div class="admin-bottom-bar" style="width:100%;">
          <div style="height:20px;"></div>
        </div>
      </div>
    </div>
  {% endif %}

  <div id="pNotification" class="p-notification">
    <h3 id="notifTitle"></h3><p id="notifMessage"></p>
    <button onclick="closeNotif()" class="btn-action" style="margin-top:1rem;">Đã hiểu</button>
  </div>
{% endblock %}

{% block scripts %}
  {% if is_player %}
    <script src="/socket.io/socket.io.js"></script><script src="/js/player.js"></script>
    <script>
      function closeNotif() { document.getElementById('pNotification').style.display = 'none'; }
      function showNotif(msg, title = 'Thông báo') {
        const n = document.getElementById('pNotification');
        document.getElementById('notifTitle').textContent = title;
        document.getElementById('notifMessage').textContent = msg;
        n.style.display = 'block';
      }
    </script>
  {% else %}
    <script>
      function togglePassword() {
        const pass = document.getElementById('adminPass');
        const svg = document.getElementById('eyeSvg');
        if (pass.type === 'password') {
          pass.type = 'text';
          svg.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
        } else {
          pass.type = 'password';
          svg.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
        }
      }

      async function handleAdminLoginDirectly() {
        const user = document.getElementById('adminUser').value;
        const password = document.getElementById('adminPass').value;
        const errorEl = document.getElementById('adminLoginError');
        if (!user || !password) return;
        try {
          const res = await fetch('/api/admin/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ user, password }) });
          const data = await res.json();
          if (data.success) { sessionStorage.setItem('adminToken', data.token); window.location.href = '/setup'; }
          else { errorEl.style.display = 'block'; }
        } catch (err) { alert('Lỗi kết nối máy chủ'); }
      }
      document.addEventListener('keypress', (e) => { if (e.key === 'Enter') handleAdminLoginDirectly(); });
    </script>
  {% endif %}
{% endblock %}
